<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Tipo de combustible -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tipo de Combustible"/>

        <Spinner
            android:id="@+id/spCombustible"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <!-- Ciudad -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ciudad"
            android:layout_marginTop="16dp"/>

        <Spinner
            android:id="@+id/spCiudad"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <!-- Zona -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Zona"
            android:layout_marginTop="16dp"/>

        <Spinner
            android:id="@+id/spZona"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <!-- Cantidad -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cantidad en galones"
            android:layout_marginTop="16dp"/>

        <EditText
            android:id="@+id/etCantidad"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Ingrese cantidad"
            android:inputType="numberDecimal"
            android:maxLines="1"/>

        <!-- Botón agregar -->
        <Button
            android:id="@+id/btnAgregar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Agregar Inventario"
            android:layout_marginTop="16dp"/>

        <!-- Resultados -->
        <TextView
            android:id="@+id/txtInventarioDiesel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Diesel: 0 gal"
            android:textSize="18sp"
            android:layout_marginTop="20dp"/>

        <TextView
            android:id="@+id/txtInventarioCorriente"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Corriente: 0 gal"
            android:textSize="18sp"
            android:layout_marginTop="10dp"/>

        <TextView
            android:id="@+id/txtInventarioExtra"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Extra: 0 gal"
            android:textSize="18sp"
            android:layout_marginTop="10dp"/>

        <TextView
            android:id="@+id/txtInventarioTotal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Total: 0 gal"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"/>

        <!-- Botón volver -->
        <Button
            android:id="@+id/btnVolver"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:text="Volver"/>

    </LinearLayout>

</ScrollView>