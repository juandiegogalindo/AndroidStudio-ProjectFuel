<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Inventario Disponible:"/>

        <TextView
            android:id="@+id/txtInventarioDisponible"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="18sp"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tipo de Combustible"/>

        <Spinner
            android:id="@+id/spTipoCombustible"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <EditText
            android:id="@+id/etSalida"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Cantidad en galones"
            android:inputType="numberDecimal"
            android:layout_marginTop="16dp"/>

        <Button
            android:id="@+id/btnRetirar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Registrar Salida"
            android:layout_marginTop="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Historial de Salidas"
            android:textSize="18sp"
            android:layout_marginTop="24dp"/>

        <ListView
            android:id="@+id/listHistorial"
            android:layout_width="match_parent"
            android:layout_height="300dp"/>

        <Button
            android:id="@+id/btnVolver"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Volver"
            android:layout_marginTop="16dp"/>

    </LinearLayout>

</ScrollView>