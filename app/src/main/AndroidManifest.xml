<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.ScrumBacklog">

        <activity android:name=".activity.distribuidor.ProgramarPedidoActivity"/>
        <activity
            android:name=".activity.logIn.LoginActivity"
            android:exported="false" /> <!-- Pantalla inicial: Login / Registro -->
        <activity
            android:name=".activity.logIn.LoginScreenActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity> <!-- Registro de usuario -->
        <activity
            android:name=".activity.logIn.RegisterActivity"
            android:exported="false" /> <!-- Actividades del selector principal -->
        <activity
            android:name=".activity.ControlInventarioActivity"
            android:exported="false" />
        <activity
            android:name=".activity.ReguladorPreciosActivity"
            android:exported="false" />
        <activity
            android:name=".activity.NotificadorActivity"
            android:exported="false" />
        <activity
            android:name=".activity.SalidasActivity"
            android:exported="false" />
        <activity
            android:name=".activity.InventarioActivity"
            android:exported="false" />
        <activity android:name=".activity.distribuidor.PedidosPendientesActivity"/>
        <activity android:name=".activity.cliente.HorariosActivity"/>
        <activity android:name=".activity.PedidosCanceladosActivity"/>
        <activity
            android:name=".activity.cliente.ConsultaActivity"
            android:exported="false" /> <!-- Selector de actividades -->
        <activity
            android:name=".activity.MainActivity"
            android:exported="false" />
    </application>

</manifest>